# Copy to .env.local and fill in real values. .env.local is gitignored.

# ---- Database (Railway Postgres) --------------------------------------------
# postgres.js connection string. For hosted providers (Railway) TLS is required;
# append ?sslmode=require if your URL does not already include it. The app and
# drizzle-kit both add sslmode=require automatically for non-local hosts.
DATABASE_URL=postgres://user:password@host:5432/database?sslmode=require

# ---- Better Auth ------------------------------------------------------------
# Secret used to sign sessions/tokens. Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-a-32-byte-random-secret
# Public base URL of this web app (no trailing slash).
BETTER_AUTH_URL=http://localhost:3000

# ---- Email (magic links) — not wired up yet --------------------------------
# Magic-link emails are currently logged to the server console. When Resend is
# wired up, set this key.
# RESEND_API_KEY=
