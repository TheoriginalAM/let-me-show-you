{
  "name": "@lmsy/desktop",
  "version": "0.1.1",
  "private": true,
  "description": "Let Me Show You — desktop recorder (Electron + React)",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build && electron-builder",
    "build:unpack": "electron-vite build && electron-builder --dir",
    "compile": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "pnpm typecheck:node && pnpm typecheck:web"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "@lmsy/shared": "workspace:*",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.7.3",
    "vite": "^5.4.11",
    "zustand": "^5.0.14"
  },
  "dependencies": {
    "@sentry/electron": "^7.15.0",
    "electron-updater": "^6.8.9",
    "ffmpeg-static": "^5.3.0"
  }
}
