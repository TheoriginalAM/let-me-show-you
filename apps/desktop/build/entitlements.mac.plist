<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Chromium/V8 need JIT under the hardened runtime. -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <!-- The bundled ffmpeg-static binary is not signed by us; allow it to load. -->
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
  <!-- Media capture. Screen recording is granted at runtime via TCC and needs
       no entitlement; camera + microphone do. -->
  <key>com.apple.security.device.camera</key>
  <true/>
  <key>com.apple.security.device.audio-input</key>
  <true/>
</dict>
</plist>
